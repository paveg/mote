{
  "name": "@paveg/mote",
  "version": "0.0.0",
  "description": "Minimal personal AI agent. Bun + TypeScript, ~1500 LOC target.",
  "type": "module",
  "private": true,
  "license": "MIT",
  "author": {
    "name": "Ryota Ikezawa",
    "email": "pavegy@gmail.com"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/paveg/mote.git"
  },
  "homepage": "https://github.com/paveg/mote#readme",
  "bugs": {
    "url": "https://github.com/paveg/mote/issues"
  },
  "keywords": [
    "ai",
    "agent",
    "personal",
    "bun",
    "typescript",
    "mcp",
    "a2a-protocol",
    "agentskills"
  ],
  "bin": {
    "mote": "src/entry/agent.ts"
  },
  "scripts": {
    "agent": "bun run src/entry/agent.ts",
    "gateway": "bun run src/entry/gateway.ts",
    "mcp-serve": "bun run src/entry/mcp-serve.ts",
    "a2a-serve": "bun run src/entry/a2a-serve.ts",
    "a2a-deploy": "wrangler deploy",
    "test": "bun test",
    "typecheck": "tsc --noEmit"
  },
  "engines": {
    "bun": ">=1.2"
  },
  "dependencies": {
    "@a2a-js/sdk": "^0.3.13",
    "@anthropic-ai/sdk": "^0.92.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@valibot/to-json-schema": "^1.6.0",
    "hono": "^4.12.16",
    "hono-a2a": "^0.1.0",
    "valibot": "^1.3.1"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5.6.0",
    "wrangler": "^4.87.0"
  }
}
